prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: IUP GL
Description: IUP OpenGL canvas control (@IUP_BACKEND@ backend)
Version: @_IUP_VERSION_RAW@
Requires: iup
Requires.private: @IUPGL_PC_REQUIRES@
Cflags: -I${includedir}
Libs: -L${libdir} -liupgl
Libs.private: @IUPGL_PC_LIBS_PRIVATE@
