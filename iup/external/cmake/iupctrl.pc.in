prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: IUP Controls
Description: IUP Matrix and advanced controls
Version: @_IUP_VERSION_RAW@
Requires: iup
Cflags: -I${includedir}
Libs: -L${libdir} -liupctrl
