{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (platform native backend)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "gtk3",
      "displayName": "GTK3 backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "gtk3"
      }
    },
    {
      "name": "gtk4",
      "displayName": "GTK4 backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "gtk4"
      }
    },
    {
      "name": "gtk2",
      "displayName": "GTK2 backend (legacy)",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "gtk2"
      }
    },
    {
      "name": "win32",
      "displayName": "Win32 backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "win32"
      }
    },
    {
      "name": "winui",
      "displayName": "WinUI backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "winui"
      }
    },
    {
      "name": "cocoa",
      "displayName": "macOS Cocoa backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "cocoa"
      }
    },
    {
      "name": "cocoatouch",
      "displayName": "iOS UIKit backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "cocoatouch"
      }
    },
    {
      "name": "cocoatouch-framework-device",
      "displayName": "iOS framework, device (arm64)",
      "inherits": "cocoatouch",
      "cacheVariables": {
        "IUP_BUILD_FRAMEWORK": "ON",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphoneos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0"
      }
    },
    {
      "name": "cocoatouch-framework-simulator-arm64",
      "displayName": "iOS framework, simulator (arm64)",
      "inherits": "cocoatouch",
      "cacheVariables": {
        "IUP_BUILD_FRAMEWORK": "ON",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0"
      }
    },
    {
      "name": "cocoatouch-framework-simulator-x86_64",
      "displayName": "iOS framework, simulator (x86_64)",
      "inherits": "cocoatouch",
      "cacheVariables": {
        "IUP_BUILD_FRAMEWORK": "ON",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0"
      }
    },
    {
      "name": "motif",
      "displayName": "Motif / X11 backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "motif"
      }
    },
    {
      "name": "qt6",
      "displayName": "Qt6 backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "qt6"
      }
    },
    {
      "name": "qt5",
      "displayName": "Qt5 backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "qt5"
      }
    },
    {
      "name": "efl",
      "displayName": "EFL backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "efl"
      }
    },
    {
      "name": "fltk",
      "displayName": "FLTK backend",
      "inherits": "default",
      "cacheVariables": {
        "IUP_BACKEND": "fltk"
      }
    },
    {
      "name": "gtk3-full",
      "displayName": "GTK3 with all optional libraries",
      "inherits": "gtk3",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "gtk4-full",
      "displayName": "GTK4 with all optional libraries",
      "inherits": "gtk4",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "gtk2-full",
      "displayName": "GTK2 with all optional libraries",
      "inherits": "gtk2",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "win32-full",
      "displayName": "Win32 with all optional libraries",
      "inherits": "win32",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "winui-full",
      "displayName": "WinUI with all optional libraries",
      "inherits": "winui",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "cocoa-full",
      "displayName": "Cocoa with all optional libraries",
      "inherits": "cocoa",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "cocoatouch-full",
      "displayName": "CocoaTouch / iOS with all optional libraries",
      "inherits": "cocoatouch",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "cocoatouch-framework-device-full",
      "displayName": "iOS framework, device (arm64), all optional libraries",
      "inherits": "cocoatouch-framework-device",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "cocoatouch-framework-simulator-arm64-full",
      "displayName": "iOS framework, simulator (arm64), all optional libraries",
      "inherits": "cocoatouch-framework-simulator-arm64",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "cocoatouch-framework-simulator-x86_64-full",
      "displayName": "iOS framework, simulator (x86_64), all optional libraries",
      "inherits": "cocoatouch-framework-simulator-x86_64",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "motif-full",
      "displayName": "Motif with all optional libraries",
      "inherits": "motif",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "qt6-full",
      "displayName": "Qt6 with all optional libraries",
      "inherits": "qt6",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "qt5-full",
      "displayName": "Qt5 with all optional libraries",
      "inherits": "qt5",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "efl-full",
      "displayName": "EFL with all optional libraries",
      "inherits": "efl",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "fltk-full",
      "displayName": "FLTK with all optional libraries",
      "inherits": "fltk",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON",
        "IUP_BUILD_CTRL": "ON",
        "IUP_BUILD_PLOT": "ON"
      }
    },
    {
      "name": "android",
      "displayName": "Android backend (arm64-v8a)",
      "inherits": "default",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "IUP_BACKEND": "android",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-22",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "android-full",
      "displayName": "Android with GL and Web optional libraries",
      "inherits": "android",
      "cacheVariables": {
        "IUP_BUILD_GL": "ON",
        "IUP_BUILD_WEB": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug build (platform native backend)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}
